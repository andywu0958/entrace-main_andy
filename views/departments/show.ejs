<div class="row">
    <div class="col-12 col-lg-4 mb-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white pb-0 border-bottom-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                <h4 class="mb-0"><i class="fas fa-building me-2 text-primary"></i>部門資訊</h4>
                <% if (currentUser && currentUser.role === 'admin') { %>
                    <a href="/departments/<%= department.id %>/edit" class="btn btn-outline-warning btn-sm">
                        <i class="fas fa-edit"></i>
                    </a>
                <% } %>
            </div>
            <div class="card-body p-4">
                <h2 class="fw-bold mb-4 text-center text-primary"><%= department.name %></h2>
                
                <div class="mb-4">
                    <h6 class="text-muted border-bottom pb-2 mb-3">基本資料</h6>
                    <div class="row mb-2">
                        <div class="col-5 text-muted">部門 ID</div>
                        <div class="col-7 fw-semibold">#<%= department.id %></div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-5 text-muted">建立時間</div>
                        <div class="col-7"><%= new Date(department.created_at).toLocaleDateString('zh-TW') %></div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-5 text-muted">資產總數</div>
                        <div class="col-7"><span class="badge bg-primary"><%= assets ? assets.length : 0 %></span></div>
                    </div>
                </div>

                <div>
                    <h6 class="text-muted border-bottom pb-2 mb-3">部門管理員</h6>
                    <% if (managers && managers.length > 0) { %>
                        <ul class="list-group list-group-flush">
                            <% managers.forEach(manager => { %>
                                <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                                    <span><i class="fas fa-user-tie text-info me-2"></i><%= manager.username %></span>
                                    <span class="badge bg-info rounded-pill">管理員</span>
                                </li>
                            <% }); %>
                        </ul>
                    <% } else { %>
                        <p class="text-muted small mb-0">目前無設定管理員</p>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-8 mb-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white pb-0 border-bottom-0 pt-4 px-4">
                <h5 class="mb-0"><i class="fas fa-boxes me-2 text-success"></i>部門資產列表</h5>
            </div>
            <div class="card-body p-4">
                <% if (assets && assets.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>名稱</th>
                                    <th>類別</th>
                                    <th>狀態</th>
                                    <th width="100" class="text-center">操作</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% assets.forEach(asset => { %>
                                    <tr>
                                        <td class="fw-semibold"><%= asset.name %></td>
                                        <td><span class="badge bg-info"><%= asset.category %></span></td>
                                        <td>
                                            <% 
                                            let statusClass = 'bg-danger';
                                            if (asset.status === 'active') statusClass = 'bg-success';
                                            if (asset.status === 'inactive') statusClass = 'bg-secondary';
                                            if (asset.status === 'maintenance') statusClass = 'bg-warning';
                                            %>
                                            <span class="badge <%= statusClass %>"><%= asset.status === 'active' ? '使用中' : asset.status === 'inactive' ? '閒置' : asset.status === 'maintenance' ? '維修中' : '已報廢' %></span>
                                        </td>
                                        <td class="text-center">
                                            <a href="/assets/<%= asset.id %>" class="btn btn-sm btn-outline-primary">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="text-center py-5">
                        <i class="fas fa-box-open fa-3x text-muted opacity-50 mb-3"></i>
                        <h6 class="text-muted">該部門目前沒有任何資產</h6>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <a href="/departments" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i>返回部門列表
        </a>
    </div>
</div>
