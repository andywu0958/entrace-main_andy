<div class="row">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white pb-0 border-bottom-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                <h4 class="mb-0"><i class="fas fa-search me-2 text-primary"></i>搜尋結果：<%= searchTerm %></h4>
                <a href="/departments" class="btn btn-outline-secondary btn-sm">
                    <i class="fas fa-arrow-left me-1"></i>返回列表
                </a>
            </div>
            
            <div class="card-body p-4">
                <% if (departments && departments.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th width="80">ID</th>
                                    <th>部門名稱</th>
                                    <th width="150" class="text-center">操作</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% departments.forEach(dept => { %>
                                    <tr>
                                        <td class="text-muted">#<%= dept.id %></td>
                                        <td class="fw-semibold"><%= dept.name %></td>
                                        <td class="text-center">
                                            <div class="btn-group btn-group-sm" role="group">
                                                <a href="/departments/<%= dept.id %>" class="btn btn-outline-primary" title="檢視">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                <a href="/departments/<%= dept.id %>/edit" class="btn btn-outline-warning" title="編輯">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="text-center py-5">
                        <div class="mb-3">
                            <i class="fas fa-search fa-3x text-muted opacity-50"></i>
                        </div>
                        <h5 class="text-muted">找不到相符的部門</h5>
                        <p class="text-muted mb-0">請嘗試使用其他關鍵字搜尋。</p>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>
