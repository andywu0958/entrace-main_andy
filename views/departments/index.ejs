<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="mb-0"><i class="fas fa-building me-2"></i>部門管理</h4>
                <% if (user.role === 'admin') { %>
                    <a href="/departments/create" class="btn btn-primary btn-sm">
                        <i class="fas fa-plus me-2"></i>新增部門
                    </a>
                <% } %>
            </div>
            
            <div class="card-body">
                <% if (departments && departments.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th width="50">ID</th>
                                    <th>部門名稱</th>
                                    <th>建立時間</th>
                                    <th>資產數量</th>
                                    <th width="150" class="text-center">操作</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% departments.forEach(dept => { %>
                                    <tr>
                                        <td class="fw-semibold">#<%= dept.id %></td>
                                        <td>
                                            <strong><%= dept.name %></strong>
                                        </td>
                                        <td>
                                            <small class="text-muted">
                                                <%= new Date(dept.created_at).toLocaleDateString('zh-TW') %>
                                            </small>
                                        </td>
                                        <td>
                                            <span class="badge bg-primary"><%= dept.asset_count || 0 %></span>
                                        </td>
                                        <td class="text-center">
                                            <div class="btn-group btn-group-sm" role="group">
                                                <a href="/departments/<%= dept.id %>" class="btn btn-outline-primary" title="檢視">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                <% if (user.role === 'admin') { %>
                                                    <a href="/departments/<%= dept.id %>/edit" class="btn btn-outline-warning" title="編輯">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <form action="/departments/<%= dept.id %>?_method=DELETE" method="POST" class="d-inline" onsubmit="return confirm('確定要刪除此部門嗎？此部門的所有資產也會被刪除，此操作無法復原。');">
                                                        <button type="submit" class="btn btn-outline-danger" title="刪除">
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                    </form>
                                                <% } %>
                                            </div>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="text-center py-5">
                        <div class="mb-3">
                            <i class="fas fa-building fa-3x text-muted"></i>
                        </div>
                        <h5 class="text-muted">暫無部門資料</h5>
                        <p class="text-muted mb-4">尚未建立任何部門。</p>
                        <% if (user.role === 'admin') { %>
                            <a href="/departments/create" class="btn btn-primary">
                                <i class="fas fa-plus me-2"></i>新增部門
                            </a>
                        <% } %>
                    </div>
                <% } %>
            </div>
            
            <div class="card-footer">
                <div class="row">
                    <div class="col-md-6">
                        <small class="text-muted">
                            共 <%= departments.length %> 個部門
                        </small>
                    </div>
                    <div class="col-md-6 text-md-end">
                        <small class="text-muted">
                            <i class="fas fa-info-circle me-1"></i>
                            部門管理功能僅限管理員使用
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>