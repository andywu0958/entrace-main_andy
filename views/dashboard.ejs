<div class="row mb-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="mb-0"><i class="fas fa-tachometer-alt me-2"></i>儀表板</h4>
                <span class="badge bg-primary">歡迎回來，<%= user.username %></span>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-6 col-md-3">
                        <div class="stat-card" style="background: linear-gradient(135deg, #3498db, #2980b9);">
                            <i class="fas fa-box"></i>
                            <div class="count">
                                <% 
                                let totalAssets = 0;
                                if (departments && departments.length > 0) {
                                    departments.forEach(dept => {
                                        totalAssets += parseInt(dept.total_assets || 0);
                                    });
                                }
                                %>
                                <%= totalAssets %>
                            </div>
                            <div class="label">總資產數量</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="stat-card" style="background: linear-gradient(135deg, #27ae60, #219653); padding: 1.2rem;">
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 6px; height: 100%;">
                                <%
                                let activeAssets = 0;
                                let inactiveAssets = 0;
                                let maintenanceAssets = 0;
                                let totalDeptAssets = 0;
                                if (departments && departments.length > 0) {
                                    departments.forEach(dept => {
                                        activeAssets += parseInt(dept.active_assets || 0);
                                        inactiveAssets += parseInt(dept.inactive_assets || 0);
                                        maintenanceAssets += parseInt(dept.maintenance_assets || 0);
                                        totalDeptAssets += parseInt(dept.total_assets || 0);
                                    });
                                }
                                let scrappedAssets = totalDeptAssets - activeAssets - inactiveAssets - maintenanceAssets;
                                %>
                                <div style="text-align: center;">
                                    <div style="font-size: 22px; font-weight: bold; color: #fff;"><%= activeAssets %></div>
                                    <div style="font-size: 13px; color: rgba(255,255,255,0.85);">使用中</div>
                                </div>
                                <div style="text-align: center;">
                                    <div style="font-size: 22px; font-weight: bold; color: #fff;"><%= inactiveAssets %></div>
                                    <div style="font-size: 13px; color: rgba(255,255,255,0.85);">閒置</div>
                                </div>
                                <div style="text-align: center;">
                                    <div style="font-size: 22px; font-weight: bold; color: #fff;"><%= maintenanceAssets %></div>
                                    <div style="font-size: 13px; color: rgba(255,255,255,0.85);">維修中</div>
                                </div>
                                <div style="text-align: center;">
                                    <div style="font-size: 22px; font-weight: bold; color: #fff;"><%= scrappedAssets %></div>
                                    <div style="font-size: 13px; color: rgba(255,255,255,0.85);">已報廢</div>
                                </div>
                            </div>
                            <div style="font-size: 13px; color: rgba(255,255,255,0.85); text-align: center; margin-top: 6px; font-weight: 500; letter-spacing: 1px;">使用資產狀態</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="stat-card" style="background: linear-gradient(135deg, #f39c12, #e67e22);">
                            <i class="fas fa-building"></i>
                            <div class="count"><%= departments ? departments.length : 0 %></div>
                            <div class="label">部門數量</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="stat-card" style="background: linear-gradient(135deg, #9b59b6, #8e44ad);">
                            <i class="fas fa-tags"></i>
                            <div class="count"><%= categoryStats ? categoryStats.length : 0 %></div>
                            <div class="label">資產類別</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-12">
        <div class="card h-100">
            <div class="card-header">
                <h5 class="mb-0"><i class="fas fa-list me-2"></i>資產列表(只列出10筆)</h5>
            </div>
            <div class="card-body">
                <% if (assets && assets.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>資產名稱</th>
                                    <th class="d-none d-md-table-cell">類別</th>
                                    <th class="d-none d-md-table-cell">部門</th>
                                    <th>狀態</th>
                                    <th class="d-none d-md-table-cell">建立時間</th>
                                    <th>操作</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% assets.forEach(asset => { %>
                                <tr>
                                    <td><%= asset.name %><br><%= asset.model %></td>
                                    <td class="d-none d-md-table-cell"><span class="badge bg-info"><%= asset.category %></span></td>
                                    <td class="d-none d-md-table-cell"><%= asset.department_name %></td>
                                    <td>
                                        <% 
                                        let statusClass = 'bg-danger';
                                        if (asset.status === 'active') statusClass = 'bg-success';
                                        if (asset.status === 'inactive') statusClass = 'bg-secondary';
                                        if (asset.status === 'maintenance') statusClass = 'bg-warning';
                                        %>
                                        <span class="badge <%= statusClass %>"><%= asset.status === 'active' ? '使用中' : asset.status === 'inactive' ? '閒置' : asset.status === 'maintenance' ? '維修中' : '已報廢' %></span>
                                    </td>
                                    <td class="d-none d-md-table-cell"><%= new Date(asset.created_at).toLocaleDateString('zh-TW') %></td>
                                    <td>
                                        <a href="/assets/<%= asset.id %>" class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="text-center py-4">
                        <i class="fas fa-box-open fa-3x text-muted mb-3"></i>
                        <p class="text-muted">目前沒有資產資料</p>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>
