<div class="container-fluid">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3"><i class="fas fa-search"></i> 搜尋資產類別</h1>
    <div>
      <a href="/asset-categories" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> 返回列表
      </a>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-body">
      <form action="/asset-categories/search" method="GET" class="row g-3">
        <div class="col-md-4">
          <label for="code" class="form-label">類別代號</label>
          <input type="text" class="form-control" id="code" name="code" value="<%= query.code || '' %>" placeholder="請輸入類別代號">
        </div>
        <div class="col-md-4">
          <label for="name" class="form-label">類別名稱</label>
          <input type="text" class="form-control" id="name" name="name" value="<%= query.name || '' %>" placeholder="請輸入類別名稱">
        </div>
        <div class="col-md-4">
          <label for="acct_code" class="form-label">資產科目代號</label>
          <input type="text" class="form-control" id="acct_code" name="acct_code" value="<%= query.acct_code || '' %>" placeholder="請輸入資產科目代號">
        </div>
        <div class="col-12 text-center">
          <button type="submit" class="btn btn-primary">
            <i class="fas fa-search"></i> 搜尋
          </button>
          <a href="/asset-categories/search" class="btn btn-secondary">
            <i class="fas fa-undo"></i> 清除條件
          </a>
        </div>
      </form>
    </div>
  </div>

  <% if (categories && categories.length > 0) { %>
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">搜尋結果</h5>
        <span class="badge bg-primary"><%= categories.length %> 筆資料</span>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover table-striped mb-0">
            <thead class="table-dark">
              <tr>
                <th>類別代號</th>
                <th>類別名稱</th>
                <th>會計科目</th>
                <th>折舊方法</th>
                <th>使用月數</th>
                <th>操作</th>
              </tr>
            </thead>
            <tbody>
              <% categories.forEach(function(category) { %>
                <tr>
                  <td><%= category.code %></td>
                  <td><%= category.name %></td>
                  <td><%= category.acct_code ? category.acct_code + ' - ' + category.acct_name : '-' %></td>
                  <td><%= category.dep_meth || '-' %></td>
                  <td><%= category.useful_mo || '-' %></td>
                  <td>
                    <a href="/asset-categories/<%= category.code %>" class="btn btn-sm btn-info" title="檢視">
                      <i class="fas fa-eye"></i>
                    </a>
                    <a href="/asset-categories/<%= category.code %>/edit" class="btn btn-sm btn-warning" title="編輯">
                      <i class="fas fa-edit"></i>
                    </a>
                    <form action="/asset-categories/<%= category.code %>/delete" method="POST" style="display:inline;" 
                          onsubmit="return confirm('確定要刪除類別「<%= category.name %>」嗎？');">
                      <button type="submit" class="btn btn-sm btn-danger" title="刪除">
                        <i class="fas fa-trash"></i>
                      </button>
                    </form>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% } else if (searched) { %>
    <div class="alert alert-info">
      <i class="fas fa-info-circle"></i> 查無符合條件的資產類別資料。
    </div>
  <% } %>
</div>
