<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css?v=3.0">
    <style>
        body {
            background-color: #f8f9fa;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .qr-container {
            max-width: 500px;
            margin: 0 auto;
            padding: 20px;
        }
        .qr-card {
            border-radius: 15px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            border: none;
        }
        .qr-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border-radius: 15px 15px 0 0;
            padding: 25px;
        }
        .qr-body {
            padding: 30px;
        }
        .qr-code {
            width: 200px;
            height: 200px;
            margin: 0 auto 20px;
            background-color: #f8f9fa;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px dashed #dee2e6;
        }
        .asset-info {
            background-color: #f8f9fa;
            border-radius: 10px;
            padding: 20px;
            margin-top: 20px;
        }
        .info-item {
            margin-bottom: 10px;
            padding-bottom: 10px;
            border-bottom: 1px solid #e9ecef;
        }
        .info-item:last-child {
            border-bottom: none;
            margin-bottom: 0;
            padding-bottom: 0;
        }
        .status-badge {
            font-size: 0.8rem;
            padding: 5px 10px;
            border-radius: 20px;
        }
        .footer {
            text-align: center;
            margin-top: 30px;
            color: #6c757d;
            font-size: 0.9rem;
        }
        .back-button {
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <div class="container mt-5">
        <div class="qr-container">
            <div class="card qr-card">
                <div class="card-header qr-header text-center">
                    <h1 class="h3 mb-0"><i class="fas fa-qrcode me-2"></i>資產資訊</h1>
                    <p class="mb-0 opacity-75">掃描 QR Code 查看資產詳細資訊</p>
                </div>
                
                <div class="card-body qr-body">
                    <% if (asset && asset.qr_code_url) { %>
                        <div class="text-center mb-4">
                            <div class="qr-code">
                                <img src="<%= asset.qr_code_url %>" alt="QR Code" class="img-fluid" style="max-width: 180px; max-height: 180px;">
                            </div>
                            <p class="text-muted mb-0">掃描此 QR Code 查看資產資訊</p>
                        </div>
                    <% } else { %>
                        <div class="text-center mb-4">
                            <div class="qr-code">
                                <i class="fas fa-qrcode fa-5x text-muted"></i>
                            </div>
                            <p class="text-muted mb-0">QR Code 尚未生成</p>
                        </div>
                    <% } %>
                    
                    <div class="asset-info">
                        <h5 class="mb-3"><i class="fas fa-info-circle me-2 text-primary"></i>資產基本資訊</h5>
                        
                        <div class="info-item">
                            <div class="row">
                                <div class="col-4 fw-semibold">資產名稱</div>
                                <div class="col-8"><%= asset.name %></div>
                            </div>
                        </div>
                        
                        <div class="info-item">
                            <div class="row">
                                <div class="col-4 fw-semibold">資產編號</div>
                                <div class="col-8">#<%= asset.id %></div>
                            </div>
                        </div>
                        
                        <% if (asset.serial_number) { %>
                        <div class="info-item">
                            <div class="row">
                                <div class="col-4 fw-semibold">序號/編號</div>
                                <div class="col-8"><%= asset.serial_number %></div>
                            </div>
                        </div>
                        <% } %>
                        
                        <div class="info-item">
                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label text-muted">資產名稱</label>
                            <div class="form-control-plaintext fw-semibold"><%= asset.name %></div>
                        </div>
                        
                        <div class="col-12 col-md-6">
                            <label class="form-label text-muted">類別</label>
                            <div>
                                <span class="badge bg-info"><%= asset.category %></span>
                            </div>
                        </div>
                        
                        <div class="col-12 col-md-6">
                            <label class="form-label text-muted">所屬部門</label>
                            <div class="form-control-plaintext">
                                <i class="fas fa-building me-2 text-muted"></i>
                                <%= asset.department_name %>
                            </div>
                        </div>
                        
                        <div class="col-12 col-md-6">
                            <label class="form-label text-muted">狀態</label>
                            <div>
                                <% if (asset.status === 'active') { %>
                                    <span class="badge bg-success">使用中</span>
                                <% } else if (asset.status === 'inactive') { %>
                                    <span class="badge bg-secondary">閒置</span>
                                <% } else if (asset.status === 'maintenance') { %>
                                    <span class="badge bg-warning">維修中</span>
                                <% } else if (asset.status === 'retired') { %>
                                    <span class="badge bg-danger">已報廢</span>
                                <% } %>
                            </div>
                        </div>
                        
                        <% if (asset.serial_number) { %>
                            <div class="col-12 col-md-6">
                                <label class="form-label text-muted">序號/編號</label>
                                <div class="form-control-plaintext">
                                    <i class="fas fa-barcode me-2 text-muted"></i>
                                    <%= asset.serial_number %>
                                </div>
                            </div>
                        <% } %>
                        
                        <% if (asset.purchase_date) { %>
                            <div class="col-12 col-md-6">
                                <label class="form-label text-muted">購買日期</label>
                                <div class="form-control-plaintext">
                                    <i class="fas fa-calendar-alt me-2 text-muted"></i>
                                    <%= new Date(asset.purchase_date).toLocaleDateString('zh-TW') %>
                                </div>
                            </div>
                        <% } %>
                        
                        <div class="col-12 col-md-6">
                            <label class="form-label text-muted">建立時間</label>
                            <div class="form-control-plaintext">
                                <i class="fas fa-clock me-2 text-muted"></i>
                                <%= new Date(asset.created_at).toLocaleString('zh-TW') %>
                            </div>
                        </div>
                        
                        <div class="col-12 col-md-6">
                            <label class="form-label text-muted">最後更新</label>
                            <div class="form-control-plaintext">
                                <i class="fas fa-sync-alt me-2 text-muted"></i>
                                <%= new Date(asset.updated_at).toLocaleString('zh-TW') %>
                            </div>
                        </div>
                        
                        <% if (asset.description) { %>
                            <div class="col-12">
                                <label class="form-label text-muted">備註說明</label>
                                <div class="form-control-plaintext bg-light rounded p-3">
                                    <%= asset.description %>
                                </div>
                            </div>
                        <% } %>
                    </div>
                
                <div class="card-footer text-center bg-transparent border-0">
                    <div class="footer">
                        <p class="mb-1">
                            <i class="fas fa-copyright me-1"></i>
                            公司資產管理系統 &copy; <%= new Date().getFullYear() %>
                        </p>
                        <p class="mb-0 small text-muted">
                            此為唯讀頁面，如需修改請登入系統
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // 自動調整 QR Code 大小
        document.addEventListener('DOMContentLoaded', function() {
            const qrCode = document.querySelector('.qr-code img');
            if (qrCode) {
                qrCode.addEventListener('load', function() {
                    console.log('QR Code loaded successfully');
                });
                qrCode.addEventListener('error', function() {
                    console.log('QR Code failed to load');
                    this.parentElement.innerHTML = '<i class="fas fa-qrcode fa-5x text-muted"></i>';
                });
            }
        });
    </script>
</body>
</html>