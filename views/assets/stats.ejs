<div class="row mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white pb-0 border-bottom-0 pt-4 px-4">
                <h4 class="mb-0"><i class="fas fa-chart-bar me-2 text-primary"></i>資產統計與分析</h4>
            </div>
            <div class="card-body p-4">
                <div class="row g-4">
                    <!-- 部門資產分佈 -->
                    <div class="col-12 col-md-6">
                        <h5 class="mb-3 text-muted border-bottom pb-2">部門資產分佈</h5>
                        <% if (departmentStats && departmentStats.length > 0) { %>
                            <div class="list-group list-group-flush">
                                <% departmentStats.forEach(dept => { %>
                                    <div class="list-group-item px-0 border-0 mb-2">
                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                            <span class="fw-semibold"><%= dept.department_name %></span>
                                            <span class="text-muted small">總計 <%= dept.total_assets %> 件</span>
                                        </div>
                                        <div class="progress" style="height: 10px;">
                                            <% 
                                            const total = parseInt(dept.total_assets || 0);
                                            const active = parseInt(dept.active_assets || 0);
                                            const percentage = total > 0 ? Math.round((active / total) * 100) : 0;
                                            %>
                                            <div class="progress-bar bg-primary" role="progressbar" style="width: <%= percentage %>%;" aria-valuenow="<%= percentage %>" aria-valuemin="0" aria-valuemax="100"></div>
                                        </div>
                                        <div class="text-end mt-1">
                                            <small class="text-success"><%= active %> 件使用中 (<%= percentage %>%)</small>
                                        </div>
                                    </div>
                                <% }); %>
                            </div>
                        <% } else { %>
                            <p class="text-muted">暫無部門資料</p>
                        <% } %>
                    </div>
                    
                    <!-- 類別資產統計 -->
                    <div class="col-12 col-md-6">
                        <h5 class="mb-3 text-muted border-bottom pb-2">資產類別統計</h5>
                        <% if (categoryStats && categoryStats.length > 0) { %>
                            <div class="table-responsive">
                                <table class="table table-hover align-middle">
                                    <thead class="table-light">
                                        <tr>
                                            <th>類別名稱</th>
                                            <th class="text-end">資產數量</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% categoryStats.forEach(cat => { %>
                                            <tr>
                                                <td><span class="badge bg-info"><%= cat.category %></span></td>
                                                <td class="text-end fw-semibold"><%= cat.count %></td>
                                            </tr>
                                        <% }); %>
                                    </tbody>
                                </table>
                            </div>
                        <% } else { %>
                            <p class="text-muted">暫無類別資料</p>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white pb-0 border-bottom-0 pt-4 px-4">
                <h5 class="mb-0"><i class="fas fa-history me-2 text-warning"></i>最近新增的資產</h5>
            </div>
            <div class="card-body p-4">
                <% if (recentAssets && recentAssets.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>資產名稱</th>
                                    <th>類別</th>
                                    <th>部門</th>
                                    <th>狀態</th>
                                    <th>新增時間</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% recentAssets.forEach(asset => { %>
                                    <tr>
                                        <td class="fw-semibold"><%= asset.name %><br><%= asset.model %></td>
                                        <td><span class="badge bg-info"><%= asset.category %></span></td>
                                        <td><%= asset.department_name %></td>
                                        <td>
                                            <% 
                                            let statusClass = 'bg-danger';
                                            if (asset.status === 'active') statusClass = 'bg-success';
                                            if (asset.status === 'inactive') statusClass = 'bg-secondary';
                                            if (asset.status === 'maintenance') statusClass = 'bg-warning';
                                            %>
                                            <span class="badge <%= statusClass %>"><%= asset.status === 'active' ? '使用中' : asset.status === 'inactive' ? '閒置' : asset.status === 'maintenance' ? '維修中' : '已報廢' %></span>
                                        </td>
                                        <td class="text-muted small"><%= new Date(asset.created_at).toLocaleDateString('zh-TW') %></td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="text-center py-4">
                        <p class="text-muted mb-0">最近無新增任何資產</p>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>
