<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="mb-0">
                    <i class="fas fa-box me-2"></i>資產詳細資訊
                    <small class="text-muted ms-2">#<%= asset.id %></small>
                </h4>
                <div>
                    <a href="/assets" class="btn btn-outline-secondary btn-sm me-2">
                        <i class="fas fa-arrow-left me-1"></i>返回列表
                    </a>
                    <a href="/assets/<%= asset.id %>/edit" class="btn btn-warning btn-sm me-2">
                        <i class="fas fa-edit me-1"></i>編輯
                    </a>
                    <form action="/assets/<%= asset.id %>?_method=DELETE" method="POST" class="d-inline" onsubmit="return confirm('確定要刪除此資產嗎？此操作無法復原。');">
                        <button type="submit" class="btn btn-danger btn-sm">
                            <i class="fas fa-trash me-1"></i>刪除
                        </button>
                    </form>
                </div>
            </div>
            
            <div class="card-body">
                <div class="row g-4">
                    <!-- 左側：基本資訊 -->
                    <div class="col-12 col-md-8">
                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                <label class="form-label text-muted">類別</label>
                                <div>
                                    <span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25">
                                        <%= asset.category %>
                                    </span>
                                </div>
                            </div>

                            <div class="col-12 col-md-6">
                                <label class="form-label text-muted">狀態</label>
                                <div>
                                    <% if (asset.status === 'active') { %>
                                        <span class="badge bg-success">使用中</span>
                                    <% } else if (asset.status === 'inactive') { %>
                                        <span class="badge bg-secondary">閒置</span>
                                    <% } else if (asset.status === 'maintenance') { %>
                                        <span class="badge bg-warning">維修中</span>
                                    <% } else if (asset.status === 'retired') { %>
                                        <span class="badge bg-danger">已報廢</span>
                                    <% } %>
                                </div>
                            </div>

                            <div class="col-12 col-md-6">
                                <label class="form-label text-muted">資產名稱</label>
                                <div class="form-control-static"><%= asset.name %></div>
                            </div>
                            
                            <% if (asset.model) { %>
                            <div class="col-12 col-md-6">
                                <label class="form-label text-muted">品牌規格</label>
                                <div class="form-control-static">
                                    <i class="fas fa-tag me-2 text-muted"></i>
                                    <%= asset.model %>
                                </div>
                            </div>
                            <% } %>
                        
                            <div class="col-12 col-md-6">
                                <label class="form-label text-muted">所屬部門</label>
                                <div class="form-control-static">
                                    <i class="fas fa-building me-2 text-muted"></i>
                                    <%= asset.department_name %>
                                </div>
                            </div>
                            
                            <% if (asset.serialno) { %>
                                <div class="col-12 col-md-6">
                                    <label class="form-label text-muted">序號/編號</label>
                                    <div class="form-control-static">
                                        <i class="fas fa-barcode me-2 text-muted"></i>
                                        <%= asset.serialno %>
                                    </div>
                                </div>
                            <% } %>
                            
                            <% if (asset.purchased_at) { %>
                                <div class="col-12 col-md-6">
                                    <label class="form-label text-muted">購買日期</label>
                                    <div class="form-control-static">
                                        <i class="fas fa-calendar-alt me-2 text-muted"></i>
                                        <%= new Date(asset.purchased_at).toLocaleDateString('zh-TW') %>
                                    </div>
                                </div>
                            <% } %>
                            
                            <div class="col-12 col-md-6">
                                <label class="form-label text-muted">建立時間</label>
                                <div class="form-control-static">
                                    <i class="fas fa-clock me-2 text-muted"></i>
                                    <%= new Date(asset.created_at).toISOString().replace('T', ' ').substring(0, 19) %>
                                </div>
                            </div>
                            
                            <div class="col-12 col-md-6">
                                <label class="form-label text-muted">最後更新</label>
                                <div class="form-control-static">
                                    <i class="fas fa-sync-alt me-2 text-muted"></i>
                                    <%= new Date(asset.updated_at).toISOString().replace('T', ' ').substring(0, 19) %>
                                </div>
                            </div>
                            
                            <% if (asset.remark) { %>
                                <div class="col-12">
                                    <label class="form-label text-muted">備註說明</label>
                                    <div class="form-control-plaintext bg-light rounded p-3">
                                        <%= asset.remark %>
                                    </div>
                                </div>
                            <% } %>
                        </div>

                        <!-- 財務資訊區塊 -->
                        <div class="row g-3 mt-4">
                            <div class="col-12">
                                <h5 class="border-bottom pb-2"><i class="fas fa-coins me-2"></i>財務資訊</h5>
                            </div>
                            <% if (asset.supplier) { %>
                            <div class="col-12 col-md-6">
                                <label class="form-label text-muted">供應廠商</label>
                                <div class="form-control-static"><%= asset.supplier %></div>
                            </div>
                            <% } %>
                            <% if (asset.quantity) { %>
                            <div class="col-12 col-md-6">
                                <label class="form-label text-muted">數量</label>
                                <div class="form-control-static"><%= asset.quantity %></div>
                            </div>
                            <% } %>
                            <% if (asset.unit) { %>
                            <div class="col-12 col-md-6">
                                <label class="form-label text-muted">單位</label>
                                <div class="form-control-static"><%= asset.unit %></div>
                            </div>
                            <% } %>
                            <% if (asset.cost) { %>
                            <div class="col-12 col-md-6">
                                <label class="form-label text-muted">成本</label>
                                <div class="form-control-static"><%= Number(asset.cost).toLocaleString('zh-TW', { minimumFractionDigits: 0, maximumFractionDigits: 0 }) %></div>
                            </div>
                            <% } %>
                            <% if (asset.warranty) { %>
                            <div class="col-12 col-md-6">
                                <label class="form-label text-muted">保固年限</label>
                                <div class="form-control-static"><%= asset.warranty %> 年</div>
                            </div>
                            <% } %>
                            <% if (asset.dep_meth) { %>
                            <div class="col-12 col-md-6">
                                <label class="form-label text-muted">折舊方法</label>
                                <div class="form-control-static"><%= asset.dep_meth %></div>
                            </div>
                            <% } %>
                            <% if (asset.dep_rate) { %>
                            <div class="col-12 col-md-6">
                                <label class="form-label text-muted">定率年折舊率</label>
                                <div class="form-control-static"><%= Number(asset.dep_rate).toLocaleString('zh-TW', { minimumFractionDigits: 2, maximumFractionDigits: 4 }) %>%</div>
                            </div>
                            <% } %>
                            <% if (asset.useful_mo) { %>
                            <div class="col-12 col-md-6">
                                <label class="form-label text-muted">耐用月數</label>
                                <div class="form-control-static"><%= asset.useful_mo %> 個月</div>
                            </div>
                            <% } %>
                            <% if (asset.residual) { %>
                            <div class="col-12 col-md-6">
                                <label class="form-label text-muted">預留殘值</label>
                                <div class="form-control-static"><%= Number(asset.residual).toLocaleString('zh-TW', { minimumFractionDigits: 0, maximumFractionDigits: 0 }) %></div>
                            </div>
                            <% } %>
                            <% if (asset.dep_start) { %>
                            <div class="col-12 col-md-6">
                                <label class="form-label text-muted">提列年月</label>
                                <div class="form-control-static"><%= asset.dep_start.substring(0, 7) %></div>
                            </div>
                            <% } %>
                            <% if (asset.unamortized_mo) { %>
                            <div class="col-12 col-md-6">
                                <label class="form-label text-muted">未攤月數</label>
                                <div class="form-control-static"><%= asset.unamortized_mo %> 個月</div>
                            </div>
                            <% } %>
                            <% if (asset.avg_dep) { %>
                            <div class="col-12 col-md-6">
                                <label class="form-label text-muted">平均法月折舊額</label>
                                <div class="form-control-static"><%= Number(asset.avg_dep).toLocaleString('zh-TW', { minimumFractionDigits: 0, maximumFractionDigits: 0 }) %></div>
                            </div>
                            <% } %>
                            <% if (asset.accumulated !== null && asset.accumulated !== undefined) { %>
                            <div class="col-12 col-md-6">
                                <label class="form-label text-muted">累積折舊</label>
                                <div class="form-control-static"><%= Number(asset.accumulated).toLocaleString('zh-TW', { minimumFractionDigits: 0, maximumFractionDigits: 0 }) %></div>
                            </div>
                            <% } %>
                            <!-- 定率法折舊計算（前端計算） -->
                            <% if (asset.cost && asset.dep_rate && asset.dep_start) { %>
                            <div class="col-12 col-md-6">
                                <label class="form-label text-muted">定率年折舊額</label>
                                <div class="form-control-static" id="show_annual_dep">計算中...</div>
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label text-muted">定率累積折舊</label>
                                <div class="form-control-static" id="show_decl_accumulated">計算中...</div>
                            </div>
                            <% } %>
                            <!-- 折舊計算用隱藏資料 -->
                            <div id="dep_data" 
                                 data-cost="<%= asset.cost || 0 %>"
                                 data-dep-rate="<%= asset.dep_rate || 0 %>"
                                 data-dep-start="<%= asset.dep_start || '' %>"
                                 data-residual="<%= asset.residual || 0 %>"
                                 style="display:none;"></div>
                            <% if (asset.custodian) { %>
                            <div class="col-12 col-md-6">
                                <label class="form-label text-muted">保管人</label>
                                <div class="form-control-static"><%= asset.custodian %></div>
                            </div>
                            <% } %>
                            <% if (asset.location) { %>
                            <div class="col-12 col-md-6">
                                <label class="form-label text-muted">保管地點</label>
                                <div class="form-control-static"><%= asset.location %></div>
                            </div>
                            <% } %>
                        </div>
                    </div>
                    
                    <!-- 右側：QR Code -->
                    <div class="col-12 col-md-4">
                        <div class="card border">
                            <div class="card-header bg-light">
                                <h6 class="mb-0"><i class="fas fa-qrcode me-2"></i>QR Code</h6>
                            </div>
                            <div class="card-body text-center">
                                <% if (asset.qr_code_url) { %>
                                    <div class="mb-3">
                                        <img src="<%= asset.qr_code_url %>" alt="QR Code" class="img-fluid rounded border" style="max-width: 200px;">
                                    </div>
                                    <p class="text-muted small mb-3">掃描此 QR Code 可查看資產資訊</p>
                                    
                                    <div class="d-grid gap-2">
                                        <a href="<%= asset.qr_code_url %>" class="btn btn-outline-primary btn-sm" download>
                                            <i class="fas fa-download me-1"></i>下載 QR Code
                                        </a>
                                        <form action="/assets/<%= asset.id %>/regenerate-qr" method="POST" class="d-inline">
                                            <button type="submit" class="btn btn-outline-warning btn-sm w-100" onclick="return confirm('確定要重新生成 QR Code 嗎？');">
                                                <i class="fas fa-sync-alt me-1"></i>重新生成 QR Code
                                            </button>
                                        </form>
                                    </div>
                                <% } else { %>
                                    <div class="py-4">
                                        <i class="fas fa-qrcode fa-3x text-muted mb-3"></i>
                                        <p class="text-muted">尚未生成 QR Code</p>
                                        <form action="/assets/<%= asset.id %>/regenerate-qr" method="POST">
                                            <button type="submit" class="btn btn-primary btn-sm">
                                                <i class="fas fa-plus me-1"></i>生成 QR Code
                                            </button>
                                        </form>
                                    </div>
                                <% } %>
                            </div>
                            <div class="card-footer bg-transparent">
                                <small class="text-muted">
                                    <i class="fas fa-info-circle me-1"></i>
                                    QR Code 可用於現場資產盤點與快速查詢
                                </small>
                            </div>
                        </div>
                        
                        <!-- 快速操作 -->
                        <div class="card border mt-4 mt-md-0">
                            <div class="card-header bg-light">
                                <h6 class="mb-0"><i class="fas fa-bolt me-2"></i>快速操作</h6>
                            </div>
                            <div class="card-body">
                                <div class="d-grid gap-2">
                                    <a href="/assets/<%= asset.id %>/view" class="btn btn-outline-info btn-sm" target="_blank">
                                        <i class="fas fa-external-link-alt me-1"></i>公開檢視頁面
                                    </a>
                                    <button type="button" class="btn btn-outline-secondary btn-sm" onclick="copyToClipboard('<%= appUrl %>/assets/<%= asset.id %>/view')">
                                        <i class="fas fa-copy me-1"></i>複製公開連結
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="card-footer">
                <div class="row align-items-center">
                    <div class="col-12 col-md-6 mb-2 mb-md-0">
                        <small class="text-muted">
                            <i class="fas fa-history me-1"></i>
                            資產 ID: <%= asset.id %> | 建立者: 系統管理員
                        </small>
                    </div>
                    <div class="col-12 col-md-6 text-md-end">
                        <a href="/assets/<%= asset.id - 1 %>" class="btn btn-outline-secondary btn-sm <%= (asset.id <= 1) ? 'disabled' : '' %> mb-1 mb-md-0">
                            <i class="fas fa-chevron-left me-1"></i>上一筆
                        </a>
                        <a href="/assets/<%= asset.id + 1 %>" class="btn btn-outline-secondary btn-sm ms-2 mb-1 mb-md-0">
                            下一筆 <i class="fas fa-chevron-right ms-1"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // 複製連結到剪貼簿
    function copyToClipboard(text) {
        navigator.clipboard.writeText(text).then(function() {
            alert('連結已複製到剪貼簿！');
        }, function(err) {
            console.error('複製失敗: ', err);
            alert('複製失敗，請手動複製連結。');
        });
    }

    // 定率法折舊計算（前端計算）- 從 data-* 屬性讀取資料
    (function() {
        var depData = document.getElementById('dep_data');
        if (!depData) return;
        
        var cost = parseFloat(depData.getAttribute('data-cost')) || 0;
        var depRate = parseFloat(depData.getAttribute('data-dep-rate')) || 0;
        var depStart = depData.getAttribute('data-dep-start') || '';
        var residual = parseFloat(depData.getAttribute('data-residual')) || 0;

        if (cost > 0 && depRate > 0 && depStart) {
            // 計算已提列月數
            var startParts = depStart.split('-');
            var startYear = parseInt(startParts[0]);
            var startMonth = parseInt(startParts[1]) - 1; // JS月份從0開始
            var now = new Date();
            
            // 計算從提列年月到現在經過的完整月數
            var monthsElapsed = (now.getFullYear() - startYear) * 12 + (now.getMonth() - startMonth);
            if (monthsElapsed < 0) monthsElapsed = 0;
            
            // 定率法：年折舊率轉月折舊率
            var monthlyRate = 1 - Math.pow(1 - depRate / 100, 1/12);
            
            // 計算定率年折舊額（第一年）
            var annualDep = cost * (depRate / 100);
            
            // 計算定率累積折舊
            var bookValue = cost;
            var accumulatedDep = 0;
            
            // 逐月計算折舊
            for (var m = 0; m < monthsElapsed; m++) {
                var monthlyDep = bookValue * monthlyRate;
                // 確保不折舊到低於殘值
                if (bookValue - monthlyDep < residual) {
                    accumulatedDep += (bookValue - residual);
                    bookValue = residual;
                    break;
                }
                accumulatedDep += monthlyDep;
                bookValue -= monthlyDep;
            }
            
            // 顯示結果
            document.getElementById('show_annual_dep').textContent = 
                Math.round(annualDep).toLocaleString('zh-TW', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
            document.getElementById('show_decl_accumulated').textContent = 
                Math.round(accumulatedDep).toLocaleString('zh-TW', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
        }
    })();
</script>
