<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h4 class="mb-0"><i class="fas fa-edit me-2"></i>編輯資產</h4>
            </div>
            <div class="card-body">
                <form action="/assets/<%= asset.id %>?_method=PUT" method="POST">
                    
                    <!-- ===== 區塊 1：基本資料 ===== -->
                    <div class="card mb-4 border-purple" style="border-color: #b39ddb !important;">
                        <div class="card-header py-2" style="background-color: #d1c4e9; color: #4a148c;">
                            <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>1. 基本資料</h5>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-12 col-md-6">
                                    <div class="mb-3">
                                        <label for="name" class="form-label">資產名稱 <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" id="name" name="name" value="<%= asset.name %>" required placeholder="例如：筆記型電腦 Dell XPS 15">
                                        <div class="form-text">請輸入資產的詳細名稱</div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6">
                                    <div class="mb-3">
                                        <label for="model" class="form-label">品牌規格</label>
                                        <input type="text" class="form-control" id="model" name="model" value="<%= asset.model || '' %>" placeholder="例如：Dell XPS 15 2024">
                                        <div class="form-text">可選：輸入品牌、型號或規格</div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6">
                                    <div class="mb-3">
                                        <label for="category" class="form-label">類別 <span class="text-danger">*</span></label>
                                        <select class="form-select" id="category" name="category" required>
                                            <option value="">請選擇類別</option>
                                            <% if (typeof categories !== 'undefined' && categories.length > 0) { %>
                                                <% categories.forEach(function(cat) { %>
                                                    <option value="<%= cat.name %>" data-dep-meth="<%= cat.dep_meth || '' %>" <%= (asset.category === cat.name) ? 'selected' : '' %>><%= cat.code %> - <%= cat.name %></option>
                                                <% }); %>
                                            <% } %>
                                        </select>
                                        <div class="form-text">選擇資產所屬類別</div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6">
                                    <div class="mb-3">
                                        <label for="status" class="form-label">狀態 <span class="text-danger">*</span></label>
                                        <select class="form-select" id="status" name="status" required>
                                            <option value="active" <%= asset.status === 'active' ? 'selected' : '' %>>使用中</option>
                                            <option value="inactive" <%= asset.status === 'inactive' ? 'selected' : '' %>>閒置</option>
                                            <option value="maintenance" <%= asset.status === 'maintenance' ? 'selected' : '' %>>維修中</option>
                                            <option value="retired" <%= asset.status === 'retired' ? 'selected' : '' %>>已報廢</option>
                                        </select>
                                        <div class="form-text">選擇資產目前狀態</div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6">
                                    <div class="mb-3">
                                        <label for="serialno" class="form-label">序號/編號 <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" id="serialno" name="serialno" value="<%= asset.serialno || '' %>" required placeholder="例如：SN-2024-001">
                                        <div class="form-text">可選：輸入資產的序號或內部編號</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ===== 區塊 2：資產取得 ===== -->
                    <div class="card mb-4 border-purple" style="border-color: #b39ddb !important;">
                        <div class="card-header py-2" style="background-color: #d1c4e9; color: #4a148c;">
                            <h5 class="mb-0"><i class="fas fa-shopping-cart me-2"></i>2. 資產取得</h5>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-12 col-md-6">
                                    <div class="mb-3">
                                        <label for="purchased_at" class="form-label">購買日期 <span class="text-danger">*</span></label>
                                        <input type="date" class="form-control" id="purchased_at" name="purchased_at" value="<%= asset.purchased_at ? new Date(asset.purchased_at).toISOString().split('T')[0] : '' %>" required>
                                        <div class="form-text">請輸入資產購買日期</div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6">
                                    <div class="mb-3">
                                        <label for="department_id" class="form-label">取得部門 <span class="text-danger">*</span></label>
                                        <select class="form-select" id="department_id" name="department_id" required>
                                            <option value="">請選擇部門</option>
                                            <% departments.forEach(dept => { %>
                                                <option value="<%= dept.id %>" <%= asset.department_id === dept.id ? 'selected' : '' %>><%= dept.name %></option>
                                            <% }); %>
                                        </select>
                                        <div class="form-text">選擇資產取得時所屬部門</div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6">
                                    <div class="mb-3">
                                        <label for="supplier" class="form-label">供應廠商</label>
                                        <input type="text" class="form-control" id="supplier" name="supplier" value="<%= asset.supplier || '' %>" placeholder="例如：某某科技股份有限公司">
                                        <div class="form-text">可選：輸入資產供應商或廠商名稱</div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-3">
                                    <div class="mb-3">
                                        <label for="quantity" class="form-label">數量 <span class="text-danger">*</span></label>
                                        <input type="number" class="form-control" id="quantity" name="quantity" value="<%= asset.quantity || '1' %>" min="1" placeholder="1" required>
                                        <div class="form-text">請輸入資產數量</div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-3">
                                    <div class="mb-3">
                                        <label for="unit" class="form-label">單位</label>
                                        <select class="form-select" id="unit" name="unit">
                                            <option value="">請選擇單位</option>
                                            <option value="台" <%= asset.unit === '台' ? 'selected' : '' %>>台</option>
                                            <option value="輛" <%= asset.unit === '輛' ? 'selected' : '' %>>輛</option>
                                            <option value="組" <%= asset.unit === '組' ? 'selected' : '' %>>組</option>
                                            <option value="張" <%= asset.unit === '張' ? 'selected' : '' %>>張</option>
                                            <option value="式" <%= asset.unit === '式' ? 'selected' : '' %>>式</option>
                                            <option value="批" <%= asset.unit === '批' ? 'selected' : '' %>>批</option>
                                        </select>
                                        <div class="form-text">可選：選擇資產計量單位</div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-3">
                                    <div class="mb-3">
                                        <label for="cost" class="form-label">成本 <span class="text-danger">*</span></label>
                                        <div class="input-group">
                                            <span class="input-group-text">$</span>
                                            <input type="number" class="form-control" id="cost" name="cost" value="<%= asset.cost || '' %>" min="0" step="1" placeholder="0" required oninput="if(this.value.includes('.')) this.value=this.value.split('.')[0]">
                                        </div>
                                        <div class="form-text">請輸入資產取得成本</div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-3">
                                    <div class="mb-3">
                                        <label for="warranty" class="form-label">保固年限</label>
                                        <div class="input-group">
                                            <input type="number" class="form-control" id="warranty" name="warranty" value="<%= asset.warranty || '' %>" min="0" step="1" placeholder="0">
                                            <span class="input-group-text">年</span>
                                        </div>
                                        <div class="form-text">可選：輸入資產保固年限</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ===== 區塊 3：折舊 ===== -->
                    <div class="card mb-4 border-purple" style="border-color: #b39ddb !important;">
                        <div class="card-header py-2" style="background-color: #d1c4e9; color: #4a148c;">
                            <h5 class="mb-0"><i class="fas fa-chart-line me-2"></i>3. 折舊</h5>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-12 col-md-6">
                                    <div class="mb-3">
                                        <label for="dep_meth" class="form-label">折舊方法 <span class="text-danger">*</span></label>
                                        <select class="form-select" id="dep_meth" name="dep_meth" required>
                                            <option value="">請選擇折舊方法</option>
                                            <option value="平均法" <%= asset.dep_meth === '平均法' ? 'selected' : '' %>>平均法</option>
                                            <option value="定率遞減法" <%= asset.dep_meth === '定率遞減法' ? 'selected' : '' %>>定率遞減法</option>
                                            <option value="不提折舊" <%= asset.dep_meth === '不提折舊' ? 'selected' : '' %>>不提折舊</option>
                                        </select>
                                        <div class="form-text">請選擇資產折舊計算方式</div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6">
                                    <div class="mb-3">
                                        <label for="useful_mo" class="form-label">耐用月數(折舊月數) <span class="text-danger">*</span></label>
                                        <div class="input-group">
                                            <input type="number" class="form-control" id="useful_mo" name="useful_mo" value="<%= asset.useful_mo || '' %>" min="1" step="1" placeholder="例如：24" required>
                                            <span class="input-group-text">月</span>
                                        </div>
                                        <div class="form-text">請輸入資產預計耐用月數</div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6">
                                    <div class="mb-3">
                                        <label for="residual" class="form-label">預留殘值</label>
                                        <div class="input-group">
                                            <span class="input-group-text">$</span>
                                            <input type="number" class="form-control" id="residual" name="residual" value="<%= asset.residual || '' %>" min="0" step="1" placeholder="0" style="background-color: #fff9c4;" readonly>
                                        </div>
                                        <div class="form-text">系統自動計算：平均法 = 總成本/(耐用月數+12)*12；定率遞減法 = 總成本/10</div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6">
                                    <div class="mb-3">
                                        <label for="dep_start" class="form-label">提列年月</label>
                                        <input type="month" class="form-control" id="dep_start" name="dep_start" value="<%= asset.dep_start ? asset.dep_start.substring(0, 7) : '' %>" style="background-color: #fff9c4;" readonly>
                                        <div class="form-text">系統自動根據購買日期計算：前半月(1~15日)=當月，後半月(16~月底)=下月</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ===== 區塊 4：開帳資料 ===== -->
                    <div class="card mb-4 border-purple" style="border-color: #b39ddb !important;">
                        <div class="card-header py-2" style="background-color: #d1c4e9; color: #4a148c;">
                            <h5 class="mb-0"><i class="fas fa-book-open me-2"></i>4. 開帳資料</h5>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-12 col-md-4">
                                    <div class="mb-3">
                                        <label for="unamortized_mo" class="form-label">未攤月數</label>
                                        <div class="input-group">
                                            <input type="text" class="form-control" id="unamortized_mo" name="unamortized_mo" value="<%= asset.unamortized_mo || '' %>" min="0" step="1" placeholder="0" style="background-color: #fff9c4;">
                                            <span class="input-group-text">月</span>
                                        </div>
                                        <div class="form-text">系統自動跟隨耐用月數</div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-4">
                                    <div class="mb-3">
                                        <label for="avg_dep" class="form-label">平均法月折舊額</label>
                                        <div class="input-group">
                                            <span class="input-group-text">$</span>
                                            <input type="number" class="form-control" id="avg_dep" name="avg_dep" value="<%= asset.avg_dep || '' %>" min="0" step="1" placeholder="0" style="background-color: #fff9c4;" readonly>
                                        </div>
                                        <div class="form-text">系統自動計算：(總成本 - 總殘值) / 耐用月數(折舊月數)</div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-4">
                                    <div class="mb-3">
                                        <label for="accumulated" class="form-label">
                                            累積折舊
                                            <i class="fas fa-table ms-1 text-success" 
                                               id="avgScheduleIcon"
                                               style="cursor: pointer;" 
                                               title="查看平均法完整逐年計算表"></i>
                                        </label>
                                        <div class="input-group">
                                            <span class="input-group-text">$</span>
                                            <input type="number" class="form-control" id="accumulated" name="accumulated" value="<%= asset.accumulated || '' %>" min="0" step="1" placeholder="0" style="background-color: #fff9c4;" readonly>
                                        </div>
                                        <div class="form-text">平均法下系統自動計算：已折舊月數 × 月折舊額</div>
                                    </div>
                                </div>
                            </div>
                            <!-- 定率遞減法專屬欄位 -->
                            <div class="row g-3" id="decliningRateFields" style="display: none;">
                                <div class="col-12 col-md-4">
                                    <div class="mb-3">
                                        <label for="rate_dep" class="form-label">定率年折舊率</label>
                                        <div class="input-group">
                                            <input type="text" class="form-control" id="rate_dep" name="rate_dep" value="<%= asset.dep_rate || '' %>" min="0" max="100" step="0.01" placeholder="例如：20" style="background-color: #d4edda;">
                                            <span class="input-group-text">%</span>
                                        </div>
                                        <div class="form-text">定率遞減法之年折舊率百分比</div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-4">
                                    <div class="mb-3">
                                        <label for="annual_dep" class="form-label">定率年折舊額</label>
                                        <div class="input-group">
                                            <span class="input-group-text">$</span>
                                            <input type="number" class="form-control" id="annual_dep" name="annual_dep" value="<%= asset.annual_dep || '' %>" min="0" step="1" placeholder="0" style="background-color: #d4edda;" readonly>
                                        </div>
                                        <div class="form-text">定率遞減法之年折舊金額</div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-4">
                                    <div class="mb-3">
                                        <label for="decl_accumulated" class="form-label">
                                            定率累積折舊
                                            <i class="fas fa-table ms-1 text-info" 
                                               id="declScheduleIcon"
                                               style="cursor: pointer;" 
                                               title="查看完整逐年計算表"></i>
                                        </label>
                                        <div class="input-group">
                                            <span class="input-group-text">$</span>
                                            <input type="number" class="form-control" id="decl_accumulated" min="0" step="1" placeholder="0" style="background-color: #d5f5e3;" readonly>
                                        </div>
                                        <div class="form-text">定率遞減法之累積折舊金額</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ===== 區塊 5：部門保管 ===== -->
                    <div class="card mb-4 border-purple" style="border-color: #b39ddb !important;">
                        <div class="card-header py-2" style="background-color: #d1c4e9; color: #4a148c;">
                            <h5 class="mb-0"><i class="fas fa-users me-2"></i>5. 部門保管</h5>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-12 col-md-6">
                                    <div class="mb-3">
                                        <label for="custodian" class="form-label">保管人</label>
                                        <select class="form-select" id="custodian" name="custodian" style="background-color: #fff9c4;">
                                            <option value="">請選擇保管人</option>
                                            <% if (typeof departmentUsers !== 'undefined' && departmentUsers.length > 0) { %>
                                                <% departmentUsers.forEach(u => { %>
                                                    <option value="<%= u.name %>" <%= (asset.custodian === u.name) ? 'selected' : '' %>><%= u.name %></option>
                                                <% }); %>
                                            <% } else { %>
                                                <option value="<%= asset.custodian || '' %>" <%= asset.custodian ? 'selected' : '' %>><%= asset.custodian || '' %></option>
                                            <% } %>
                                        </select>
                                        <div class="form-text">選擇資產保管人員</div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6">
                                    <div class="mb-3">
                                        <label for="location" class="form-label">保管地點</label>
                                        <input type="text" class="form-control" id="location" name="location" value="<%= asset.location || '' %>" placeholder="例如：3樓辦公室A區">
                                        <div class="form-text">可選：輸入資產存放或保管位置</div>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="mb-3">
                                        <label for="remark" class="form-label">備註說明</label>
                                        <textarea class="form-control" id="remark" name="remark" rows="3" placeholder="可選：輸入資產的詳細說明或特殊注意事項"><%= asset.remark || '' %></textarea>
                                        <div class="form-text">可選：輸入資產的保管注意事項或補充說明</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- ===== 提示訊息 ===== -->
                    <div class="row mt-4">
                        <div class="col-12">
                            <div class="alert alert-info">
                                <i class="fas fa-info-circle me-2"></i>
                                <strong>注意：</strong> 修改資產資訊後請確認資料正確性，儲存後將更新相關記錄。
                            </div>
                        </div>
                    </div>
                    
                    <!-- ===== 按鈕區 ===== -->
                    <div class="row mt-4">
                        <div class="col-12">
                            <div class="d-flex flex-column flex-md-row justify-content-md-between gap-2">
                                <a href="/assets/<%= asset.id %>" class="btn btn-outline-secondary order-md-1">
                                    <i class="fas fa-arrow-left me-2"></i>取消編輯
                                </a>
                                <button type="submit" class="btn btn-primary order-md-2">
                                    <i class="fas fa-save me-2"></i>儲存變更
                                </button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            
            <div class="card-footer">
                <small class="text-muted">
                    <i class="fas fa-lightbulb me-1"></i>
                    提示：修改資產資訊後，系統將自動更新相關的折舊計算與記錄。
                </small>
            </div>
        </div>
    </div>
</div>

<!-- ===== 完整逐年計算表模態視窗 ===== -->
<div class="modal fade" id="depreciationScheduleModal" tabindex="-1" aria-labelledby="depreciationScheduleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header" style="background-color: #d1c4e9; color: #4a148c;">
                <h5 class="modal-title" id="depreciationScheduleModalLabel">
                    <i class="fas fa-table me-2"></i>完整逐年計算表
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <!-- 摘要資訊 -->
                <div class="row mb-3" id="scheduleSummary">
                    <div class="col-12 col-md-3 mb-2">
                        <div class="card bg-light">
                            <div class="card-body py-2 px-3">
                                <small class="text-muted">資產名稱</small>
                                <div class="fw-bold" id="schedAssetName">-</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-md-3 mb-2">
                        <div class="card bg-light">
                            <div class="card-body py-2 px-3">
                                <small class="text-muted">總成本</small>
                                <div class="fw-bold" id="schedTotalCost">-</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-md-3 mb-2">
                        <div class="card bg-light">
                            <div class="card-body py-2 px-3">
                                <small class="text-muted">預留殘值</small>
                                <div class="fw-bold" id="schedResidual">-</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-md-3 mb-2">
                        <div class="card bg-light">
                            <div class="card-body py-2 px-3">
                                <small class="text-muted">年折舊率</small>
                                <div class="fw-bold" id="schedRate">-</div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- 表格 -->
                <div class="table-responsive">
                    <table class="table table-bordered table-hover table-sm" id="scheduleTable">
                        <thead class="table-secondary">
                            <tr>
                                <th class="text-center" style="width: 100px;" id="schedPeriodHeader">年度</th>
                                <th class="text-end" style="width: 150px;" id="schedBeginHeader">年初帳面價值</th>
                                <th class="text-end" style="width: 150px;" id="schedDepHeader">年折舊額</th>
                                <th class="text-end" style="width: 150px;">累積折舊</th>
                                <th class="text-end" style="width: 150px;" id="schedEndHeader">年底帳面價值</th>
                            </tr>
                        </thead>
                        <tbody id="scheduleTableBody">
                            <tr>
                                <td colspan="5" class="text-center text-muted">請先輸入資產資料</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-1"></i>關閉
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    // 設定購買日期的預設值為今天
    document.addEventListener('DOMContentLoaded', function() {
        const purchaseDateInput = document.getElementById('purchased_at');
        const depreciationStartInput = document.getElementById('dep_start');
        
        // 提列年月預設規則：
        //   前半月(1~15日) → 當月開始提列
        //   後半月(16~月底) → 下月開始提列
        function setDepreciationStartFromPurchaseDate() {
            if (purchaseDateInput && purchaseDateInput.value && depreciationStartInput) {
                const purchaseDate = new Date(purchaseDateInput.value + 'T00:00:00');
                const day = purchaseDate.getDate();
                // 後半月(16日以後)才加1個月
                let year = purchaseDate.getFullYear();
                let month = purchaseDate.getMonth();
                if (day >= 16) {
                    month += 1;
                    if (month > 11) {
                        month = 0;
                        year += 1;
                    }
                }
                depreciationStartInput.value = `${year}-${String(month + 1).padStart(2, '0')}`;
            }
        }
        setDepreciationStartFromPurchaseDate();
        
        // 當購買日期變更時，同步更新提列年月
        if (purchaseDateInput) {
            purchaseDateInput.addEventListener('change', function() {
                setDepreciationStartFromPurchaseDate();
                const method = depMethSelect.value;
                if (method === '定率遞減法') {
                    // 定率遞減法不適用未攤月數，保持為空
                    unamortizedMoInput.value = '';
                    calcRateDepreciation();
                    calcDecliningAccumulated();
                    calcAnnualDepreciation();
                } else {
                    syncUnamortizedMonths();
                    calcAccumulatedDepreciation();
                    calcRateDepreciation();
                    calcDecliningAccumulated();
                    calcAnnualDepreciation();
                }
            });
        }
        
        // 自動聚焦第一個輸入欄位
        const nameInput = document.getElementById('name');
        if (nameInput) {
            nameInput.focus();
        }

        // === 類別變更時自動帶出折舊方法 ===
        const categorySelect = document.getElementById('category');
        if (categorySelect) {
            categorySelect.addEventListener('change', function() {
                const selectedOption = this.options[this.selectedIndex];
                const depMeth = selectedOption ? selectedOption.getAttribute('data-dep-meth') : '';
                if (depMeth) {
                    depMethSelect.value = depMeth;
                    // 觸發折舊方法變更事件以更新相關欄位
                    const event = new Event('change', { bubbles: true });
                    depMethSelect.dispatchEvent(event);
                }
            });
        }

        // === 未攤月數自動跟隨耐用月數 ===
        function syncUnamortizedMonths() {
            const months = parseInt(usefulMoInput.value);
            if (!isNaN(months) && months > 0) {
                let result = months;
                const method = depMethSelect.value;
                if (method === '平均法' && depreciationStartInput && depreciationStartInput.value) {
                    const now = new Date();
                    const currentYearMonth = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}`;
                    
                    if (depreciationStartInput.value <= currentYearMonth) {
                        // 1. 初始減1：提列年月已開始，先減1個月
                        let deductMonths = 1;
                        
                        // 2. 每月1日再減1：計算從提列年月到當前年月經過的月數
                        const startParts = depreciationStartInput.value.split('-');
                        const startYear = parseInt(startParts[0]);
                        const startMonth = parseInt(startParts[1]);
                        const currentYear = now.getFullYear();
                        const currentMonth = now.getMonth() + 1;
                        
                        // 經過的月數 = (當前年 - 提列年) * 12 + (當前月 - 提列月)
                        const elapsedMonths = (currentYear - startYear) * 12 + (currentMonth - startMonth);
                        
                        // 每月1日再減1，但初始減1已經算了一個月，所以從第2個月開始算
                        if (elapsedMonths > 0) {
                            deductMonths += elapsedMonths;
                        }
                        
                        result = Math.max(0, months - deductMonths);
                    }
                }
                unamortizedMoInput.value = result;
            } else {
                unamortizedMoInput.value = '';
            }
        }

        // === 預留殘值自動計算（平均法 & 定率遞減法）===
        const costInput = document.getElementById('cost');
        const quantityInput = document.getElementById('quantity');
        const usefulMoInput = document.getElementById('useful_mo');
        const residualInput = document.getElementById('residual');
        const depMethSelect = document.getElementById('dep_meth');
        const unamortizedMoInput = document.getElementById('unamortized_mo');
        const avgDepInput = document.getElementById('avg_dep');
        const rateDepInput = document.getElementById('rate_dep');
        const annualDepInput = document.getElementById('annual_dep');
        const decliningRateFields = document.getElementById('decliningRateFields');

        function calcResidualValue() {
            const method = depMethSelect.value;
            if (method !== '平均法' && method !== '定率遞減法') return;

            const cost = parseFloat(costInput.value);
            const quantity = parseInt(quantityInput.value) || 1;
            const months = parseInt(usefulMoInput.value);

            if (isNaN(cost) || cost <= 0) return;

            const totalCost = cost * quantity;
            let residual;

            if (method === '平均法') {
                // 平均法：預留殘值 = (成本 × 數量) / (耐用月數 + 12) * 12，四捨五入
                if (isNaN(months) || months <= 0) return;
                residual = Math.round(totalCost / (months + 12) * 12);
            } else if (method === '定率遞減法') {
                // 定率遞減法：預留殘值 = (成本 × 數量) / 10，四捨五入
                residual = Math.round(totalCost / 10);
            }

            residualInput.value = residual;
        }

        // === 平均法月折舊額自動計算 ===
        // 公式：(總成本 - 總殘值) / 耐用月數(折舊月數)，四捨五入
        // 總成本 = 成本 × 數量
        // 總殘值 = 預留殘值（已由 calcResidualValue 計算為總殘值）
        function calcMonthlyDepreciation() {
            const method = depMethSelect.value;
            if (method === '定率遞減法') {
                avgDepInput.value = '';
                unamortizedMoInput.value = '';
                avgDepInput.disabled = true;
                return;
            }
            if (method !== '平均法') {
                avgDepInput.value = '';
                avgDepInput.placeholder = '0.00';
                avgDepInput.disabled = false;
                return;
            }

            // 從定率遞減法切換回平均法時，先將耐用月數同步到未攤月數
            const usefulMonths = parseInt(usefulMoInput.value);
            if (usefulMonths > 0 && !unamortizedMoInput.value) {
                unamortizedMoInput.value = usefulMonths;
            }

            const cost = parseFloat(costInput.value);
            const quantity = parseInt(quantityInput.value) || 1;
            const residual = parseFloat(residualInput.value);
            // 使用耐用月數(折舊月數)作為計算基準
            const months = parseInt(usefulMoInput.value);

            if (isNaN(cost) || cost <= 0) return;
            if (isNaN(months) || months <= 0) return;

            const totalCost = cost * quantity;
            // residualInput 已經是 calcResidualValue 計算出的總殘值，無需再乘以數量
            const totalResidual = isNaN(residual) ? 0 : residual;
            const depreciation = Math.round((totalCost - totalResidual) / months);

            avgDepInput.value = depreciation;
        }

        // === 累積折舊自動計算 ===
        // 當折舊方法=平均法，且未攤月數開始倒扣時，將平均法月折舊額自動累加到累積折舊
        function calcAccumulatedDepreciation() {
            const method = depMethSelect.value;
            if (method !== '平均法') {
                // 非平均法時不清空累積折舊，讓使用者自行輸入
                return;
            }

            const avgDep = parseFloat(avgDepInput.value);
            const usefulMonths = parseInt(usefulMoInput.value);
            const unamortizedMo = parseInt(unamortizedMoInput.value);

            if (isNaN(avgDep) || avgDep <= 0) return;
            if (isNaN(usefulMonths) || usefulMonths <= 0) return;
            if (isNaN(unamortizedMo) || unamortizedMo < 0) return;

            // 若未攤月數還不需減1時（未攤月數 = 耐用月數），累積折舊為0
            if (unamortizedMo === usefulMonths) {
                accumulatedInput.value = '0';
                return;
            }

            // 若有減1（未攤月數 < 耐用月數），才開始累積計算
            // 已折舊月數 = 耐用月數 - 未攤月數
            // 累積折舊 = 已折舊月數 × 平均法月折舊額
            const depreciatedMonths = usefulMonths - unamortizedMo;
            if (depreciatedMonths > 0) {
                const accumulated = Math.round(depreciatedMonths * avgDep);
                accumulatedInput.value = accumulated;
            } else {
                accumulatedInput.value = '0';
            }
        }

        // === 定率遞減法相關功能 ===
        function toggleDecliningRateFields() {
            const method = depMethSelect.value;
            if (method === '定率遞減法') {
                decliningRateFields.style.display = 'flex';
            } else {
                decliningRateFields.style.display = 'none';
                rateDepInput.value = '';
                annualDepInput.value = '';
                declAccumulatedInput.value = '';
            }
        }

        // === 定率年折舊率自動計算 ===
        // 公式：年折舊率 = 1 - (預留殘值 / 總成本)^(12 / 耐用月數)
        // 結果轉換為百分比
        function calcRateDepreciation() {
            const method = depMethSelect.value;
            if (method !== '定率遞減法') {
                rateDepInput.value = '';
                return;
            }

            const cost = parseFloat(costInput.value);
            const quantity = parseInt(quantityInput.value) || 1;
            const residual = parseFloat(residualInput.value);
            const months = parseInt(usefulMoInput.value);

            if (isNaN(cost) || cost <= 0) return;
            if (isNaN(residual) || residual <= 0) return;
            if (isNaN(months) || months <= 0) return;

            const totalCost = cost * quantity;
            
            // 年折舊率 = 1 - (預留殘值 / 總成本)^(12 / 耐用月數)
            const rateDecimal = 1 - Math.pow(residual / totalCost, 12 / months);
            
            // 轉換為百分比，保留2位小數
            const ratePercent = Math.round(rateDecimal * 10000) / 100;
            
            rateDepInput.value = ratePercent.toFixed(2);
            
            // 計算完年折舊率後，自動計算累積折舊和年折舊額
            calcDecliningAccumulated();
            calcAnnualDepreciation();
        }

        // === 定率遞減法累積折舊自動計算 ===
        // 從提列年月到當前年月，計算經過的完整年數，逐年計算累積折舊
        // 公式 A（不扣殘值）：年折舊額 = 年初帳面價值 × 年折舊率
        // 年初帳面價值 = 總成本 - 累積折舊（不扣殘值）
        // 但折舊後的帳面價值不得低於預留殘值
        const declAccumulatedInput = document.getElementById('decl_accumulated');
        function calcDecliningAccumulated() {
            const method = depMethSelect.value;
            if (method !== '定率遞減法') return;

            const cost = parseFloat(costInput.value);
            const quantity = parseInt(quantityInput.value) || 1;
            const residual = parseFloat(residualInput.value);
            const rate = parseFloat(rateDepInput.value);
            const depStart = depreciationStartInput ? depreciationStartInput.value : '';

            if (isNaN(cost) || cost <= 0) return;
            if (isNaN(rate) || rate <= 0) return;
            if (!depStart) return;

            const totalCost = cost * quantity;
            const totalResidual = isNaN(residual) ? 0 : residual;

            // 計算從提列年月到當前年月經過的完整年數
            const now = new Date();
            const startParts = depStart.split('-');
            const startYear = parseInt(startParts[0]);
            const startMonth = parseInt(startParts[1]);
            const currentYear = now.getFullYear();
            const currentMonth = now.getMonth() + 1;

            // 經過的月數
            const elapsedMonths = (currentYear - startYear) * 12 + (currentMonth - startMonth);
            // 完整年數（無條件捨去）
            const fullYears = Math.floor(elapsedMonths / 12);

            if (fullYears <= 0) {
                declAccumulatedInput.value = '0';
                return;
            }

            // 逐年計算累積折舊（公式 A：不扣殘值）
            // 年初帳面價值 = 總成本 - 累積折舊（不扣殘值）
            let accumulated = 0;
            let bookValue = totalCost; // 年初帳面價值

            for (let y = 0; y < fullYears; y++) {
                // 年折舊額 = 年初帳面價值 × 年折舊率
                let yearDep = Math.round(bookValue * (rate / 100));
                
                // 確保折舊後的帳面價值不低於殘值
                if (bookValue - yearDep < totalResidual) {
                    yearDep = bookValue - totalResidual;
                }
                
                accumulated += yearDep;
                bookValue -= yearDep;
            }

            declAccumulatedInput.value = Math.round(accumulated);
        }

        // === 定率年折舊額自動計算 ===
        // 從提列年月到當前年月，計算經過的完整年數，逐年模擬折舊
        // 顯示最後一個完整年度的年折舊額
        // 公式 A（不扣殘值）：年折舊額 = 年初帳面價值 × 年折舊率
        // 但折舊後的帳面價值不得低於預留殘值
        function calcAnnualDepreciation() {
            const method = depMethSelect.value;
            if (method !== '定率遞減法') {
                annualDepInput.value = '';
                return;
            }

            const cost = parseFloat(costInput.value);
            const quantity = parseInt(quantityInput.value) || 1;
            const residual = parseFloat(residualInput.value);
            const rate = parseFloat(rateDepInput.value);
            const depStart = depreciationStartInput ? depreciationStartInput.value : '';

            if (isNaN(cost) || cost <= 0) return;
            if (isNaN(rate) || rate <= 0) return;
            if (!depStart) return;

            const totalCost = cost * quantity;
            const totalResidual = isNaN(residual) ? 0 : residual;

            // 計算從提列年月到當前年月經過的完整年數
            const now = new Date();
            const startParts = depStart.split('-');
            const startYear = parseInt(startParts[0]);
            const startMonth = parseInt(startParts[1]);
            const currentYear = now.getFullYear();
            const currentMonth = now.getMonth() + 1;

            // 經過的月數
            const elapsedMonths = (currentYear - startYear) * 12 + (currentMonth - startMonth);
            // 完整年數（無條件捨去）
            const fullYears = Math.floor(elapsedMonths / 12);

            if (fullYears <= 0) {
                annualDepInput.value = '0';
                return;
            }

            // 逐年模擬折舊，記錄每年的折舊額
            let bookValue = totalCost;
            let lastYearDep = 0;

            for (let y = 0; y < fullYears; y++) {
                // 年折舊額 = 年初帳面價值 × 年折舊率
                let yearDep = Math.round(bookValue * (rate / 100));
                
                // 確保折舊後的帳面價值不低於殘值
                if (bookValue - yearDep < totalResidual) {
                    yearDep = bookValue - totalResidual;
                }
                
                lastYearDep = yearDep;
                bookValue -= yearDep;
            }

            // 顯示最後一個完整年度的年折舊額
            annualDepInput.value = Math.round(lastYearDep);
        }

        const accumulatedInput = document.getElementById('accumulated');

        // 當成本、數量、預留殘值、未攤月數、折舊方法任一變動時重新計算月折舊額
        costInput.addEventListener('input', function() {
            calcResidualValue();
            calcMonthlyDepreciation();
            calcAccumulatedDepreciation();
            calcRateDepreciation();
            calcDecliningAccumulated();
            calcAnnualDepreciation();
        });
        quantityInput.addEventListener('input', function() {
            calcResidualValue();
            calcMonthlyDepreciation();
            calcAccumulatedDepreciation();
            calcRateDepreciation();
            calcDecliningAccumulated();
            calcAnnualDepreciation();
        });
        usefulMoInput.addEventListener('input', function() {
            calcResidualValue();
            const method = depMethSelect.value;
            if (method === '定率遞減法') {
                // 定率遞減法不適用未攤月數，保持為空
                unamortizedMoInput.value = '';
            } else {
                syncUnamortizedMonths();
            }
            calcMonthlyDepreciation();
            calcAccumulatedDepreciation();
            calcRateDepreciation();
            calcDecliningAccumulated();
            calcAnnualDepreciation();
        });
        depMethSelect.addEventListener('change', function() {
            const method = depMethSelect.value;
            
            // 顯示/隱藏定率遞減法專屬欄位
            toggleDecliningRateFields();
            
            // 當選擇「不提折舊」時，清空相關欄位
            if (method === '不提折舊') {
                usefulMoInput.value = '';
                residualInput.value = '';
                unamortizedMoInput.value = '';
                avgDepInput.value = '';
                return;
            }
            
            // 當選擇「定率遞減法」時，清空平均法相關欄位
            if (method === '定率遞減法') {
                unamortizedMoInput.value = '';
                avgDepInput.value = '';
                accumulatedInput.value = '';
                calcResidualValue();
                calcRateDepreciation();
                calcDecliningAccumulated();
                return;
            }
            
            // 從定率遞減法切換回平均法時，先將耐用月數同步到未攤月數
            if (method === '平均法') {
                syncUnamortizedMonths();
            }
            
            calcResidualValue();
            calcMonthlyDepreciation();
            calcAccumulatedDepreciation();
            calcAnnualDepreciation();
        });

        // 當未攤月數變更時，重新計算累積折舊
        unamortizedMoInput.addEventListener('input', function() {
            calcAccumulatedDepreciation();
        });

        // 定率遞減法：當年折舊率變更時重新計算年折舊額
        rateDepInput.addEventListener('input', function() {
            calcAnnualDepreciation();
        });

        // 頁面載入時初始化定率遞減法欄位的顯示狀態
        toggleDecliningRateFields();
        
        // 頁面載入時，若為定率遞減法，未攤月數應為空白（不適用）
        if (depMethSelect.value === '定率遞減法') {
            unamortizedMoInput.value = '';
            // 頁面載入時一併計算定率年折舊率、定率累積折舊和年折舊額
            calcRateDepreciation();
            calcDecliningAccumulated();
            calcAnnualDepreciation();
        } else {
            // === 方案 A：頁面載入時自動重新計算 ===
            // 從資料庫讀出的未攤月數可能不是最新值（例如資料庫存的是60，但實際上已過1個月應為59）
            // 因此頁面載入時強制重新計算未攤月數、月折舊額、累積折舊
            syncUnamortizedMonths();
            calcMonthlyDepreciation();
            calcAccumulatedDepreciation();
            calcAnnualDepreciation();
        }

        // === 完整逐年計算表功能（平均法 - 按月顯示） ===
        // 點擊平均法累積折舊旁的圖示時，動態生成平均法完整逐年計算表（以月為單位）
        const avgScheduleIcon = document.getElementById('avgScheduleIcon');
        if (avgScheduleIcon) {
            avgScheduleIcon.addEventListener('click', function(e) {
                e.preventDefault();
                
                const method = depMethSelect.value;
                if (method !== '平均法') {
                    alert('請先選擇折舊方法為「平均法」');
                    return;
                }
                
                const cost = parseFloat(costInput.value);
                const quantity = parseInt(quantityInput.value) || 1;
                const residual = parseFloat(residualInput.value);
                const months = parseInt(usefulMoInput.value);
                const depStart = depreciationStartInput ? depreciationStartInput.value : '';
                const assetName = document.getElementById('name') ? document.getElementById('name').value : '';
                
                if (isNaN(cost) || cost <= 0) {
                    alert('請先輸入有效的成本');
                    return;
                }
                if (isNaN(months) || months <= 0) {
                    alert('請先輸入有效的耐用月數');
                    return;
                }
                if (!depStart) {
                    alert('請先輸入購買日期以產生提列年月');
                    return;
                }
                
                const totalCost = cost * quantity;
                const totalResidual = isNaN(residual) ? 0 : residual;
                const monthlyDep = Math.round((totalCost - totalResidual) / months);
                
                // 更新摘要資訊
                document.getElementById('schedAssetName').textContent = assetName || '-';
                document.getElementById('schedTotalCost').textContent = '$' + totalCost.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                document.getElementById('schedResidual').textContent = '$' + totalResidual.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                document.getElementById('schedRate').textContent = '平均法（月折舊額：$' + monthlyDep.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + '）';
                
                // 計算平均法完整逐年計算表（以月為單位）
                // 從提列年月開始，逐月顯示到耐用月數結束
                const startParts = depStart.split('-');
                const startYear = parseInt(startParts[0]);
                const startMonth = parseInt(startParts[1]);
                
                let bookValue = totalCost;
                let accumulated = 0;
                const rows = [];
                
                for (let m = 0; m < months; m++) {
                    // 計算當前月份
                    const currentYear = startYear + Math.floor((startMonth - 1 + m) / 12);
                    const currentMonth = ((startMonth - 1 + m) % 12) + 1;
                    const monthLabel = currentYear + '/' + String(currentMonth).padStart(2, '0');
                    
                    // 月初帳面價值
                    const beginBookValue = bookValue;
                    
                    // 月折舊額
                    let monthDep = monthlyDep;
                    
                    // 最後一個月：確保折舊後的帳面價值等於殘值
                    if (m === months - 1) {
                        monthDep = bookValue - totalResidual;
                    }
                    
                    // 確保月折舊額不為負數
                    if (monthDep < 0) monthDep = 0;
                    
                    accumulated += monthDep;
                    bookValue -= monthDep;
                    
                    rows.push({
                        monthLabel: monthLabel,
                        beginBookValue: beginBookValue,
                        monthDep: monthDep,
                        accumulated: accumulated,
                        endBookValue: bookValue
                    });
                }
                
                // 渲染表格
                const tbody = document.getElementById('scheduleTableBody');
                tbody.innerHTML = '';
                
                if (rows.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted">無計算結果</td></tr>';
                } else {
                    rows.forEach(function(row) {
                        const tr = document.createElement('tr');
                        tr.innerHTML = `
                            <td class="text-center">${row.monthLabel}</td>
                            <td class="text-end">$${row.beginBookValue.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</td>
                            <td class="text-end">$${row.monthDep.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</td>
                            <td class="text-end">$${row.accumulated.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</td>
                            <td class="text-end">$${row.endBookValue.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</td>
                        `;
                        tbody.appendChild(tr);
                    });
                }
                
                // 手動顯示模態視窗
                const modal = new bootstrap.Modal(document.getElementById('depreciationScheduleModal'));
                modal.show();
            });
        }

        // === 完整逐年計算表功能（定率遞減法） ===
        // 點擊圖示時，動態生成定率遞減法完整逐年計算表
        const declScheduleIcon = document.getElementById('declScheduleIcon');
        if (declScheduleIcon) {
            declScheduleIcon.addEventListener('click', function(e) {
                // 阻止 Bootstrap 默認的 modal 行為，我們自己控制
                e.preventDefault();
                
                const method = depMethSelect.value;
                if (method !== '定率遞減法') {
                    alert('請先選擇折舊方法為「定率遞減法」');
                    return;
                }
                
                const cost = parseFloat(costInput.value);
                const quantity = parseInt(quantityInput.value) || 1;
                const residual = parseFloat(residualInput.value);
                const rate = parseFloat(rateDepInput.value);
                const months = parseInt(usefulMoInput.value);
                const depStart = depreciationStartInput ? depreciationStartInput.value : '';
                const assetName = document.getElementById('name') ? document.getElementById('name').value : '';
                
                if (isNaN(cost) || cost <= 0) {
                    alert('請先輸入有效的成本');
                    return;
                }
                if (isNaN(rate) || rate <= 0) {
                    alert('請先輸入有效的年折舊率');
                    return;
                }
                if (isNaN(months) || months <= 0) {
                    alert('請先輸入有效的耐用月數');
                    return;
                }
                if (!depStart) {
                    alert('請先輸入購買日期以產生提列年月');
                    return;
                }
                
                const totalCost = cost * quantity;
                const totalResidual = isNaN(residual) ? 0 : residual;
                
                // 更新摘要資訊
                document.getElementById('schedAssetName').textContent = assetName || '-';
                document.getElementById('schedTotalCost').textContent = '$' + totalCost.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                document.getElementById('schedResidual').textContent = '$' + totalResidual.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                document.getElementById('schedRate').textContent = rate.toFixed(2) + '%';
                
                // 更新表格標題（定率遞減法以年為單位）
                document.getElementById('schedPeriodHeader').textContent = '年度';
                document.getElementById('schedBeginHeader').textContent = '年初帳面價值';
                document.getElementById('schedDepHeader').textContent = '年折舊額';
                document.getElementById('schedEndHeader').textContent = '年底帳面價值';
                
                // 計算完整逐年折舊表
                // 從提列年月開始，到帳面價值低於殘值為止
                const startParts = depStart.split('-');
                const startYear = parseInt(startParts[0]);
                const startMonth = parseInt(startParts[1]);
                
                let yearIndex = 0;
                let bookValue = totalCost;
                let accumulated = 0;
                const rows = [];
                
                // 最多計算 50 年防止無限循環
                while (bookValue > totalResidual && yearIndex < 50) {
                    const currentYear = startYear + yearIndex;
                    const yearLabel = '第 ' + (yearIndex + 1) + ' 年 (' + currentYear + '/' + String(startMonth).padStart(2, '0') + '~' + (currentYear + 1) + '/' + String(startMonth).padStart(2, '0') + ')';
                    
                    // 年初帳面價值
                    const beginBookValue = bookValue;
                    
                    // 年折舊額 = 年初帳面價值 × 年折舊率
                    let yearDep = Math.round(bookValue * (rate / 100));
                    
                    // 確保折舊後的帳面價值不低於殘值
                    if (bookValue - yearDep < totalResidual) {
                        yearDep = bookValue - totalResidual;
                    }
                    
                    accumulated += yearDep;
                    bookValue -= yearDep;
                    
                    rows.push({
                        yearLabel: yearLabel,
                        beginBookValue: beginBookValue,
                        yearDep: yearDep,
                        accumulated: accumulated,
                        endBookValue: bookValue
                    });
                    
                    yearIndex++;
                }
                
                // 渲染表格
                const tbody = document.getElementById('scheduleTableBody');
                tbody.innerHTML = '';
                
                if (rows.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted">無計算結果</td></tr>';
                } else {
                    rows.forEach(function(row) {
                        const tr = document.createElement('tr');
                        tr.innerHTML = `
                            <td class="text-center">${row.yearLabel}</td>
                            <td class="text-end">$${row.beginBookValue.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</td>
                            <td class="text-end">$${row.yearDep.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</td>
                            <td class="text-end">$${row.accumulated.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</td>
                            <td class="text-end">$${row.endBookValue.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</td>
                        `;
                        tbody.appendChild(tr);
                    });
                }
                
                // 手動顯示模態視窗
                const modal = new bootstrap.Modal(document.getElementById('depreciationScheduleModal'));
                modal.show();
            });
        }
    });
</script>
