<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-0 shadow-lg">
            <div class="card-body p-5">
                <!-- Logo 和標題 -->
                <div class="text-center mb-4">
                    <div class="bg-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                        <i class="fas fa-user-plus fa-2x text-white"></i>
                    </div>
                    <h2 class="fw-bold text-primary">新增使用者</h2>
                    <p class="text-muted">請填寫以下資訊建立新使用者</p>
                </div>
                
                <!-- Flash 訊息 -->
                <% if (error_msg && error_msg.length > 0) { %>
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="fas fa-exclamation-circle me-2"></i><%= error_msg %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% } %>
                
                <% if (success_msg && success_msg.length > 0) { %>
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="fas fa-check-circle me-2"></i><%= success_msg %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% } %>
                
                <!-- 註冊表單 -->
                <form action="/auth/register" method="POST">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="username" class="form-label fw-semibold">
                                <i class="fas fa-user me-2 text-primary"></i>使用者名稱 <span class="text-danger">*</span>
                            </label>
                            <input type="text" 
                                   class="form-control" 
                                   id="username" 
                                   name="username" 
                                   placeholder="輸入使用者名稱"
                                   required 
                                   autofocus>
                            <div class="form-text">請輸入 3-20 個字元的英文或數字</div>
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <label for="role" class="form-label fw-semibold">
                                <i class="fas fa-user-tag me-2 text-primary"></i>使用者角色 <span class="text-danger">*</span>
                            </label>
                            <select class="form-select" id="role" name="role" required>
                                <option value="">請選擇角色</option>
                                <option value="admin">系統管理員</option>
                                <option value="dept_manager">部門管理員</option>
                            </select>
                            <div class="form-text">選擇使用者的權限角色</div>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="password" class="form-label fw-semibold">
                                <i class="fas fa-lock me-2 text-primary"></i>密碼 <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <input type="password" 
                                       class="form-control" 
                                       id="password" 
                                       name="password" 
                                       placeholder="輸入密碼"
                                       required>
                                <button class="btn btn-outline-secondary" type="button" id="togglePassword">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </div>
                            <div class="form-text">請輸入至少 6 個字元的密碼</div>
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <label for="confirmPassword" class="form-label fw-semibold">
                                <i class="fas fa-lock me-2 text-primary"></i>確認密碼 <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <input type="password" 
                                       class="form-control" 
                                       id="confirmPassword" 
                                       name="confirmPassword" 
                                       placeholder="再次輸入密碼"
                                       required>
                                <button class="btn btn-outline-secondary" type="button" id="toggleConfirmPassword">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </div>
                            <div class="form-text">請再次輸入密碼以確認</div>
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label for="department_id" class="form-label fw-semibold">
                            <i class="fas fa-building me-2 text-primary"></i>所屬部門 <span class="text-danger">*</span>
                        </label>
                        <select class="form-select" id="department_id" name="department_id" required>
                            <option value="">請選擇部門</option>
                            <% departments.forEach(dept => { %>
                                <option value="<%= dept.id %>"><%= dept.name %></option>
                            <% }); %>
                        </select>
                        <div class="form-text">選擇使用者所屬部門</div>
                    </div>
                    
                    <div class="mb-4">
                        <label for="email" class="form-label fw-semibold">
                            <i class="fas fa-envelope me-2 text-primary"></i>電子郵件
                        </label>
                        <input type="email" 
                               class="form-control" 
                               id="email" 
                               name="email" 
                               placeholder="輸入電子郵件 (選填)">
                        <div class="form-text">可選：輸入使用者的電子郵件</div>
                    </div>
                    
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg fw-semibold py-3">
                            <i class="fas fa-user-plus me-2"></i>建立使用者
                        </button>
                        <a href="/" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-2"></i>返回首頁
                        </a>
                    </div>
                </form>
                
                <!-- 注意事項 -->
                <div class="mt-4 pt-3 border-top">
                    <div class="alert alert-light border">
                        <h6 class="alert-heading mb-2"><i class="fas fa-exclamation-triangle text-warning me-2"></i>注意事項</h6>
                        <ul class="mb-0 small">
                            <li>只有系統管理員可以建立新使用者</li>
                            <li>使用者名稱必須是唯一的，不能重複</li>
                            <li>系統管理員擁有所有權限</li>
                            <li>部門管理員只能管理自己部門的資產</li>
                            <li>建議使用者在首次登入後立即變更密碼</li>
                        </ul>
                    </div>
                </div>
            </div>
            
            <!-- 頁尾 -->
            <div class="card-footer bg-transparent border-0 text-center py-4">
                <small class="text-muted">
                    <i class="fas fa-copyright me-1"></i>公司資產管理系統 &copy; <%= new Date().getFullYear() %>
                </small>
            </div>
        </div>
    </div>
</div>

<!-- JavaScript 功能 -->
<script>
    // 切換密碼可見性
    document.getElementById('togglePassword').addEventListener('click', function () {
        const passwordInput = document.getElementById('password');
        const icon = this.querySelector('i');
        
        if (passwordInput.type === 'password') {
            passwordInput.type = 'text';
            icon.classList.remove('fa-eye');
            icon.classList.add('fa-eye-slash');
            this.setAttribute('title', '隱藏密碼');
        } else {
            passwordInput.type = 'password';
            icon.classList.remove('fa-eye-slash');
            icon.classList.add('fa-eye');
            this.setAttribute('title', '顯示密碼');
        }
    });
    
    // 切換確認密碼可見性
    document.getElementById('toggleConfirmPassword').addEventListener('click', function () {
        const confirmPasswordInput = document.getElementById('confirmPassword');
        const icon = this.querySelector('i');
        
        if (confirmPasswordInput.type === 'password') {
            confirmPasswordInput.type = 'text';
            icon.classList.remove('fa-eye');
            icon.classList.add('fa-eye-slash');
            this.setAttribute('title', '隱藏密碼');
        } else {
            confirmPasswordInput.type = 'password';
            icon.classList.remove('fa-eye-slash');
            icon.classList.add('fa-eye');
            this.setAttribute('title', '顯示密碼');
        }
    });
    
    // 密碼確認驗證
    document.querySelector('form').addEventListener('submit', function(event) {
        const password = document.getElementById('password').value;
        const confirmPassword = document.getElementById('confirmPassword').value;
        
        if (password !== confirmPassword) {
            event.preventDefault();
            alert('密碼與確認密碼不相符，請重新輸入！');
            document.getElementById('password').focus();
        }
    });
    
    // 自動聚焦使用者名稱欄位
    document.addEventListener('DOMContentLoaded', function() {
        const usernameInput = document.getElementById('username');
        if (usernameInput) {
            usernameInput.focus();
        }
    });
</script>